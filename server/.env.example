# Server (ShiftPass auto-rotate agent)
PORT=8787

# Gemini agent
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-pro
GEMINI_FALLBACK_MODEL=gemini-2.5-flash

# 32-byte hex (64 chars) key for the AES-256-GCM vault. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
VAULT_KEY=

# Comma-separated domain allowlist. Use '*' or leave empty to allow any domain
# (dry runs only recommended).
ALLOWED_DOMAINS=

# When true, the agent walks the flow but does NOT submit the final new password.
DRY_RUN=true

# Max agent steps per goal before aborting.
MAX_AGENT_STEPS=40
