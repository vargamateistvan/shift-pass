{
  "name": "shift-pass-server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "postinstall": "node -e \"if (process.env.VERCEL) { console.log('Skipping Playwright browser download on Vercel'); process.exit(0); }\" && playwright install chromium"
  },
  "dependencies": {
    "@google/genai": "^1.19.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "playwright": "^1.49.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^24.12.3",
    "tsx": "^4.19.2",
    "typescript": "~6.0.2"
  }
}
